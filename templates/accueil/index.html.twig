{% extends 'base.html.twig' %}

{% block title %}Accueil
{% endblock %}

{% block stylesheet %}
	{{ parent() }}
	<style>
		* {
			box-sizing: border-box;
		}
	</style>
{% endblock %}

{% block body %}
	<h1>👋 Bienvenue sur notre application Symfony !</h1>
	<p>Ceci est votre première application construite avec le framework
		<strong>Symfony 7.4</strong>.</p>
	<p>Date actuelle :
		{{ "now"|date("d/m/Y H:i") }}</p>
{% endblock %}
